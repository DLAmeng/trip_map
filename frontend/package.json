{
  "name": "trip-map-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "trip_map 项目的 React + TypeScript + Vite 前端,与根目录的 Express 后端配对,共享 /api/*。",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
